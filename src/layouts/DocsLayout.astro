---
import { getCollection } from 'astro:content';
import '../styles/global.css';

interface Props {
  title: string;
  currentSlug: string;
}

const { title, currentSlug } = Astro.props;

const allDocs = await getCollection('docs');
const sorted = allDocs.sort((a, b) => a.data.nav_order - b.data.nav_order);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Directive</title>
    <link rel="icon" href="/assets/logo-icon-dark.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      /* Scrollbar — sidebar */
      .sidebar-scroll {
        scrollbar-width: thin;
        scrollbar-color: #1e1e2e transparent;
      }
      .sidebar-scroll::-webkit-scrollbar { width: 4px; }
      .sidebar-scroll::-webkit-scrollbar-track { background: transparent; }
      .sidebar-scroll::-webkit-scrollbar-thumb { background-color: #1e1e2e; border-radius: 9999px; }
      .sidebar-scroll::-webkit-scrollbar-thumb:hover { background-color: #6366f1; }

      /* Scrollbar — main content */
      .content-scroll {
        scrollbar-width: thin;
        scrollbar-color: #1e1e2e transparent;
      }
      .content-scroll::-webkit-scrollbar { width: 6px; }
      .content-scroll::-webkit-scrollbar-track { background: transparent; }
      .content-scroll::-webkit-scrollbar-thumb { background-color: #1e1e2e; border-radius: 9999px; }
      .content-scroll::-webkit-scrollbar-thumb:hover { background-color: #6366f1; }
    </style>
  </head>
  <body class="bg-page text-gray-100 antialiased font-sans flex flex-col md:h-screen md:overflow-hidden">

    <!-- Top nav -->
    <nav class="shrink-0 border-b border-border bg-page/80 backdrop-blur-md z-50">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between gap-4">
        <div class="flex items-center gap-4">
          <a href="/">
            <img src="/assets/logo-full-dark.svg" alt="Directive" class="h-7" />
          </a>
          <span class="text-gray-500 text-sm">/ docs</span>
        </div>
        <!-- Mobile menu toggle -->
        <button id="sidebar-toggle" class="md:hidden p-2 rounded text-gray-400 hover:text-white hover:bg-surface transition-colors" aria-label="Toggle menu">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </nav>

    <!-- Mobile sidebar drawer -->
    <div id="sidebar-overlay" class="fixed inset-x-0 bottom-0 top-[61px] z-40 hidden md:hidden">
      <div class="absolute inset-0 bg-black/60" id="sidebar-backdrop"></div>
      <div class="relative w-64 h-full bg-surface border-r border-border py-6 px-4 overflow-y-auto sidebar-scroll">
        <nav>
          <ul class="space-y-1">
            {sorted.map((entry) => (
              <li>
                <a
                  href={`/docs/${entry.id}`}
                  class={[
                    'block px-3 py-1.5 rounded text-sm transition-colors',
                    entry.id === currentSlug
                      ? 'bg-page text-white font-medium'
                      : 'text-gray-400 hover:text-gray-200 hover:bg-page/50',
                  ].join(' ')}
                >
                  {entry.data.title}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </div>

    <!-- Body -->
    <div class="flex flex-1 max-w-6xl mx-auto w-full px-6 min-h-0 flex-col md:flex-row">

      <!-- Sidebar (desktop only) -->
      <aside class="hidden md:block w-56 shrink-0 py-8 pr-6 overflow-y-auto sidebar-scroll">
        <nav>
          <ul class="space-y-1">
            {sorted.map((entry) => (
              <li>
                <a
                  href={`/docs/${entry.id}`}
                  class={[
                    'block px-3 py-1.5 rounded text-sm transition-colors',
                    entry.id === currentSlug
                      ? 'bg-surface text-white font-medium'
                      : 'text-gray-400 hover:text-gray-200 hover:bg-surface/50',
                  ].join(' ')}
                >
                  {entry.data.title}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>

      <!-- Content -->
      <main id="doc-content" class="flex-1 py-8 md:pl-8 md:border-l border-border min-w-0 overflow-y-auto content-scroll">
        <slot />
      </main>

    </div>

    <!-- Footer -->
    <footer class="shrink-0 py-8 px-6 border-t border-border">
      <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-6">
        <div class="flex items-center gap-6 text-sm text-gray-500">
          <a href="https://github.com/cceconi/directive" target="_blank" rel="noopener noreferrer" class="hover:text-gray-300 transition-colors">Directive</a>
          <a href="https://github.com/cceconi/directive-cli" target="_blank" rel="noopener noreferrer" class="hover:text-gray-300 transition-colors">Directive CLI</a>
          <span>MIT Licence</span>
        </div>
        <p class="text-sm text-gray-600">Built with Directive</p>
      </div>
    </footer>

    <!-- Back to top button -->
    <button
      id="back-to-top"
      aria-label="Back to top"
      class="fixed bottom-6 right-6 z-50 p-2.5 rounded-full bg-surface border border-border text-gray-400 hover:text-white hover:border-indigo-500/60 shadow-lg transition-all duration-200 opacity-0 pointer-events-none"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
      </svg>
    </button>

    <script>
      const toggle = document.getElementById('sidebar-toggle');
      const overlay = document.getElementById('sidebar-overlay');
      const backdrop = document.getElementById('sidebar-backdrop');
      toggle?.addEventListener('click', () => overlay?.classList.toggle('hidden'));
      backdrop?.addEventListener('click', () => overlay?.classList.add('hidden'));

      const backToTop = document.getElementById('back-to-top');
      const content = document.getElementById('doc-content');

      // On desktop, <main> scrolls. On mobile, window scrolls.
      const isContentScroller = () => content !== null && content.scrollHeight > content.clientHeight && window.getComputedStyle(content).overflowY !== 'visible';

      function onScroll() {
        const top = isContentScroller() ? content!.scrollTop : window.scrollY;
        if (top > 300) {
          backToTop?.classList.remove('opacity-0', 'pointer-events-none');
        } else {
          backToTop?.classList.add('opacity-0', 'pointer-events-none');
        }
      }

      content?.addEventListener('scroll', onScroll);
      window.addEventListener('scroll', onScroll);

      backToTop?.addEventListener('click', () => {
        if (isContentScroller()) {
          content!.scrollTo({ top: 0, behavior: 'smooth' });
        } else {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      });
    </script>

  </body>
</html>
