---
interface Props {
  floating?: boolean;
  bordered?: boolean;
}
const { floating = false, bordered = true } = Astro.props;
---
<nav
  id={floating ? 'site-nav' : undefined}
  style={floating ? 'left: 50%; transform: translateX(-50%); right: auto; width: 100%; transition: top 0.35s ease, width 0.35s ease, border-radius 0.35s ease, background 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;' : undefined}
  class:list={[
    'z-50',
    floating
      ? ['fixed top-0 bg-page/80 backdrop-blur-md', bordered && 'border-b border-border']
      : ['shrink-0 bg-page/80 backdrop-blur-md', bordered && 'border-b border-border']
  ]}
>
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" aria-label="Directive home">
      <img src="/assets/logo-full-dark.svg" alt="Directive" class="h-7" />
    </a>
    <div class="flex items-center gap-6">
      <a href="/docs/getting-started" class="text-sm text-gray-400 hover:text-white transition-colors">Documentation</a>
      <a
        href="https://github.com/cceconi"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
        </svg>
        GitHub
      </a>
    </div>
  </div>
</nav>

{floating && (
  <div id="nav-curtain" style="position: fixed; top: 0; left: 0; right: 0; height: 0; background: rgba(10, 10, 15, 0.5); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); z-index: 49; transition: height 0.35s ease;"></div>
)}

{floating && (
  <script is:inline>
    (function () {
      const nav = document.getElementById('site-nav');
      const curtain = document.getElementById('nav-curtain');
      if (!nav) return;
      function update() {
        if (window.scrollY > 60) {
          nav.style.top = '12px';
          nav.style.width = 'min(calc(100vw - 32px), 72rem)';
          nav.style.borderRadius = '1rem';
          nav.style.border = '1px solid rgba(30, 30, 46, 0.95)';
          nav.style.background = 'rgba(10, 10, 15, 0.75)';
          nav.style.backdropFilter = 'blur(16px)';
          nav.style.webkitBackdropFilter = 'blur(16px)';
          nav.style.boxShadow = '0 8px 32px rgba(0,0,0,0.45), 0 0 0 1px rgba(99,102,241,0.07)';
          if (curtain) curtain.style.height = '24px';
        } else {
          nav.style.top = '';
          nav.style.width = '100%';
          nav.style.borderRadius = '';
          nav.style.border = '';
          nav.style.background = '';
          nav.style.backdropFilter = '';
          nav.style.webkitBackdropFilter = '';
          nav.style.boxShadow = '';
          if (curtain) curtain.style.height = '0';
        }
      }
      window.addEventListener('scroll', update, { passive: true });
    })();
  </script>
)}
